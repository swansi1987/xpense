# Xpense Environment Configuration
# Copy this file to .env.local for development or .env for production

# Database - SQLite (recommended for simple VPS/self-hosting)
# File will be created automatically on first run
DATABASE_URL="file:./xpense.db"

# Optional: put the DB in a subfolder (recommended for Docker volumes)
# DATABASE_URL="file:./data/xpense.db"

# For PostgreSQL (if you outgrow SQLite):
# DATABASE_URL="postgresql://user:password@localhost:5432/xpense?schema=public"

# Session / Auth secret (generate a long random string)
SESSION_SECRET="change-this-to-a-long-random-string-in-production"

# Port the app runs on
PORT=3000

# Public base URL of your deployed instance (used for share links)
# Example: https://xpense.yourdomain.com
PUBLIC_URL="http://localhost:3000"

# Optional: Default currency for new trips
DEFAULT_CURRENCY="INR"
